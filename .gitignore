# ──────────────────────────────────────────
# Knowtique — .gitignore
# ──────────────────────────────────────────

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/
*.whl
.venv/
venv/
env/
.env
.env.*
!.env.example

# ── Database ──
*.db
*.sqlite3

# ── Node ──
node_modules/
dist/
dist-ssr/
*.local
.cache/

# ── IDE / Editor ──
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Data / Output ──
backend/data/output/
backend/knowtique.db

# ── Build Artifacts ──
frontend/dist/

# ── Presentation files (internal) ──
*.pptx
