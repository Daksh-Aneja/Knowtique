# ──────────────────────────────────────────────────────────
# Knowtique — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────

# ── Security ──
# REQUIRED: Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ── Database ──
# SQLite (default for local dev — no setup required):
DATABASE_URL=sqlite+aiosqlite:///./knowtique.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://knowtique:password@localhost:5432/knowtique

# ── LLM Configuration (BYOK — Bring Your Own Key) ──
# At least one provider is needed for full functionality.
# The platform works without LLM keys but LLM-powered features will be disabled.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Optional: External Services ──
# These are only needed if you use the corresponding features.

# Redis (caching)
# REDIS_URL=redis://localhost:6379/0

# Neo4j (knowledge graph)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# Kafka (event streaming)
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Slack (elicitation)
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# TimescaleDB (temporal decay)
# TIMESCALE_URL=postgresql://user:pass@localhost:5433/knowtique_temporal

# Temporal (workflow orchestration)
# TEMPORAL_HOST=localhost:7233

# ── CORS ──
# Comma-separated list of allowed origins (defaults to localhost)
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── Application ──
# DEBUG=true
# API_PREFIX=/api/v1
