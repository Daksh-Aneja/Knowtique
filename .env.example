# ═══════════════════════════════════════════════════════════
# KAEOS / Knowtique — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────
APP_NAME=Knowtique
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=          # REQUIRED: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=        # REQUIRED: Secret for /admin/api-keys bootstrap endpoint

# ── Database ──────────────────────────────────────────────
# Dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./knowtique.db
# Production (PostgreSQL via docker-compose):
# DATABASE_URL=postgresql+asyncpg://knowtique:your_password@localhost:5432/knowtique
# POSTGRES_PASSWORD=your_secure_password_here

# ── Redis (optional — for caching, rate limiting) ────────
REDIS_URL=redis://localhost:6379/0

# ── LLM API Keys (BYOK — at least one required) ─────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── CORS Origins ─────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]

# ── Slack (optional) ─────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── Frontend ─────────────────────────────────────────────
VITE_API_BASE=http://localhost:8001/api/v1
